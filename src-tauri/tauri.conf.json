{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kocotree Skills",
  "version": "0.1.0",
  "identifier": "n.kktree.tauri-study",
  "build": {
    "beforeDevCommand": "pnpm run dev:lan",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kocotree Skills",
        "width": 1280,
        "height": 820,
        "minWidth": 820,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
